{
  "name": "medpredict",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"npm run dev:backend\" \"wait-on tcp:8000 && npm run dev:frontend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && hypercorn main:app --reload --bind 0.0.0.0:8000"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "wait-on": "^9.0.4"
  }
}
